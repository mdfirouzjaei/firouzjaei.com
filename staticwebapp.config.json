{
  "routes": [
    {
      "route": "/api/state",
      "methods": ["GET"],
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/api/state",
      "methods": ["PUT"],
      "allowedRoles": ["authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/.auth/*",
      "/assets/*",
      "/*.css",
      "/*.js",
      "/*.json",
      "/*.svg",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.webp",
      "/*.woff2"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "platform": {
    "apiRuntime": "node:20"
  }
}
